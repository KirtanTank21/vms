# Supabase — use the SERVICE ROLE key (bypasses RLS for push subscription lookups)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# VAPID keys for Web Push — generate once with:
#   python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PUBLIC:', v.public_key); print('PRIVATE:', v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:you@example.com

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173
